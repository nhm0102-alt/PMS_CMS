{
  "name": "LicenseTransaction",
  "type": "object",
  "properties": {
    "property_id": {
      "type": "string"
    },
    "transaction_type": {
      "type": "string",
      "enum": [
        "new_license",
        "renewal",
        "upgrade",
        "downgrade",
        "cancellation",
        "payment"
      ],
      "default": "new_license"
    },
    "license_type": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "currency": {
      "type": "string",
      "default": "VND"
    },
    "payment_method": {
      "type": "string"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "pending",
        "paid",
        "failed",
        "refunded"
      ],
      "default": "pending"
    },
    "period_start": {
      "type": "string",
      "format": "date"
    },
    "period_end": {
      "type": "string",
      "format": "date"
    },
    "notes": {
      "type": "string"
    },
    "invoice_number": {
      "type": "string"
    }
  },
  "required": [
    "property_id"
  ]
}
