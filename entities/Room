{
  "name": "Room",
  "type": "object",
  "properties": {
    "property_id": {
      "type": "string"
    },
    "room_type_id": {
      "type": "string"
    },
    "room_number": {
      "type": "string"
    },
    "room_name": {
      "type": "string",
      "description": "T\u00ean g\u1ecdi c\u1ee7a ph\u00f2ng, VD: Daisy, Rose..."
    },
