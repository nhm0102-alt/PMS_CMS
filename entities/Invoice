{
  "name": "Invoice",
  "type": "object",
  "properties": {
    "property_id": {
      "type": "string"
    },
    "reservation_id": {
      "type": "string"
    },
    "guest_id": {
      "type": "string"
    },
    "invoice_number": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "checkout",
        "deposit",
        "service",
        "refund",
        "credit_note"
      ],
      "default": "checkout"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "total": {
            "type": "number"
          },
          "category": {
            "type": "string"
          }
        }
      }
    },
    "subtotal": {
      "type": "number"
    },
    "tax_amount": {
      "type": "number"
    },
    "discount_amount": {
      "type": "number",
      "default": 0
    },
    "total_amount": {
      "type": "number"
    },
    "paid_amount": {
      "type": "number",
      "default": 0
    },
    "balance_due": {
      "type": "number",
      "default": 0
    },
    "payment_method": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "issued",
        "paid",
        "partially_paid",
        "overdue",
        "cancelled"
      ],
      "default": "draft"
    },
    "notes": {
      "type": "string"
    },
    "issue_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "property_id"
  ]
}
